# Terraform working directory
**/.terraform/*

# Terraform state (may contain infrastructure details or secrets)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files can contain sensitive values
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# Editor and operating-system files
.vscode/
.idea/
.DS_Store
Thumbs.db
